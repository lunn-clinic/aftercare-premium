{
  "name": "lunn-aftercare-cards",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 4100",
    "dev:home": "next dev --webpack -p 4100",
    "dev:ko-basic": "DEFAULT_PATH=/ko/basic next dev --webpack -p 4101",
    "dev:ko-premium": "DEFAULT_PATH=/ko/premium next dev --webpack -p 4102",
    "dev:en": "DEFAULT_PATH=/en/premium next dev --webpack -p 4103",
    "dev:zh": "DEFAULT_PATH=/zh/premium next dev --webpack -p 4104",
    "dev:all": "concurrently -n home,ko-basic,ko-premium,en,zh -c blue,green,magenta,yellow,red \"npm:dev:home\" \"npm:dev:ko-basic\" \"npm:dev:ko-premium\" \"npm:dev:en\" \"npm:dev:zh\"",
    "start:home": "next start -p 4100",
    "start:ko-basic": "DEFAULT_PATH=/ko/basic next start -p 4101",
    "start:ko-premium": "DEFAULT_PATH=/ko/premium next start -p 4102",
    "start:en": "DEFAULT_PATH=/en/premium next start -p 4103",
    "start:zh": "DEFAULT_PATH=/zh/premium next start -p 4104",
    "start:all": "concurrently -n home,ko-basic,ko-premium,en,zh -c blue,green,magenta,yellow,red \"npm:start:home\" \"npm:start:ko-basic\" \"npm:start:ko-premium\" \"npm:start:en\" \"npm:start:zh\"",
    "build": "next build --webpack",
    "start": "next start -p 4100",
    "lint": "eslint"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
